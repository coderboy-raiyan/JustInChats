{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],

    "allowJs": true,
    "checkJs": true,
    "noEmit": true,

    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["**/*.js"],
  "exclude": ["node_modules", "dist"]
}
